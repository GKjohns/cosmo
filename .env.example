# Supabase project URL (Settings → API → Project URL).
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key. Used by the client.
SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key. Server-only — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI API key for the chat + completion endpoints.
OPENAI_API_KEY=sk-your-key

# Inngest local dev keys (optional — leave blank to use the dev server defaults).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Sprint 3 (email layer) ---
# Resend API key for transactional email.
# RESEND_API_KEY=
# Default From address for editorial mail (e.g. "Cosmo <hello@yourdomain.com>").
# RESEND_FROM=
# From address for operator alerts (e.g. "Cosmo Alerts <alerts@yourdomain.com>").
# RESEND_ALERT_FROM=
# Recipient for operator alerts (single email).
# RESEND_ALERT_TO=
# Set to "1" in dev to actually send via Resend; otherwise sends are no-op'd.
# RESEND_ALLOW_SEND=

# --- Sprint 3 (AI Gateway, optional) ---
# Vercel AI Gateway key — when set, MODELS registry routes through the gateway.
# AI_GATEWAY_API_KEY=

# --- Sprint 5 (Stripe billing) ---
# Leave the Stripe vars blank to run in stub mode — every endpoint short-circuits
# to canned responses and the `stripe` SDK never loads. Set them all to flip live.
#
# Stripe secret key (sk_test_… or sk_live_…).
# STRIPE_SECRET_KEY=
# Stripe webhook signing secret (whsec_…) for /api/stripe/webhook signature verification.
# STRIPE_WEBHOOK_SECRET=
# Stripe publishable key (pk_test_… or pk_live_…) used by the client (Stripe.js).
# STRIPE_PUBLISHABLE_KEY=
# Default Stripe Price ID for the Pro plan (price_…). Used by the checkout endpoint.
# STRIPE_PRICE_ID=
